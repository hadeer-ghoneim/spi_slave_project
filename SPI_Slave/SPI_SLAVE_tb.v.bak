module SPI_SLAVE_tb ();
    parameter MEM_DEPTH = 256,ADDR_SIZE = 8;
    reg MOSI;
    reg SS_n;
    reg clk;
    reg rst_n;
    reg [7:0] tx_data;
    reg tx_valid;
    wire [9:0] rx_data;
    wire rx_valid;
    wire MISO;
    reg [9:0] addr,data,dummy;
    // instantiation SPI_SLAVE module
    TEST u0 (MOSI,SS_n,clk,rst_n,tx_valid,tx_data,MISO,rx_data,rx_valid);

    integer i;

    initial begin
        clk = 0;
        forever begin
        #1    clk = ~clk;
        end
    end


    initial begin
        rst_n = 0;
        @(negedge clk);
        rst_n = 1;

        // test master to write addr want to write it
        addr = {2'b00,8'h50};
        data = {2'b01,8'h90};
        SS_n = 0;
        MOSI = 0;
        @(negedge clk);
        for ( i = 0 ; i < 10 ; i = i + 1 ) begin
            MOSI = addr[i];
            @(negedge clk);
        end
        SS_n = 1;
        repeat(1) @(negedge clk);
        SS_n = 0;
        repeat(1) @(negedge clk);
        if (rx_data != addr) begin
                $display ("ERROR, rx_data out is incorrect rx_data=%h",rx_data);
                $stop;
            end

        // test master to write data 
        SS_n = 0;
        MOSI = 0;
        @(negedge clk);
        for ( i = 0 ; i < 10 ; i = i + 1 ) begin
            MOSI = data[i];
            @(negedge clk);
        end
        SS_n = 1;
        repeat(1) @(negedge clk);
        SS_n = 0;
        repeat(1) @(negedge clk);
        if (rx_data != data) begin
                $display ("ERROR, rx_data out is incorrect rx_data=%h",rx_data);
                $stop;
            end

        // test slave to read addr form mem want to read it
        addr = {2'b10,8'h50};
        SS_n = 0;
        MOSI = 1;
        @(negedge clk);
        for ( i = 0 ; i < 10 ; i = i + 1 ) begin
            MOSI = addr[i];
            @(negedge clk);
            end
            if (rx_data != addr) begin
                $display ("ERROR, rx_data out is incorrect rx_data=%h",rx_data);
                $stop;
            end

        // test slave to write data from mem to master
        dummy = {2'b11,8'hff};
        SS_n = 0;
        tx_valid = 1;
        tx_data = data;
        MOSI = 1;
        @(negedge clk);
        for ( i = 0 ; i < 8 ; i = i + 1 ) begin
            MOSI = dummy;
            @(negedge clk);
            // self check
        if (MISO != data[i]) begin
            $display ("ERROR, MISO out is incorrect MISO=%h",MISO);
            $stop;
        end
        end
        
        
        $stop;

    end
        

    initial begin
        $monitor("MOSI=%d,MISO=%d,SS_n=%d,rst_n=%d,rx_data=%d,rx_valid=%d,tx_data=%d,tx_valid=%d",MOSI,MISO,SS_n,rst_n,rx_data,rx_valid,tx_data,tx_valid);
    end


endmodule