module SPI_TOP_tb ();
    parameter MEM_DEPTH = 256,ADDR_SIZE = 8;
    reg MOSI;
    reg SS_n;
    reg clk;
    reg rst_n;
    wire MISO;
    reg [9:0] addr,data,dummy;
    // instantiation SPI_TOP module
    SPI_TOP u0 (MOSI,MISO,SS_n,clk,rst_n);

    initial begin
        clk = 0;
        forever begin
        #1    clk = ~clk;
        end
    end

    integer i;

    initial begin
        rst_n = 0;
        @(negedge clk);
        rst_n = 1;

        // test master to write addr want to write it
        addr = {2'b00,8'h50};
        data = {2'b01,8'h90};
        SS_n = 0;
        MOSI = 0;
        @(negedge clk);
        for ( i = 0 ; i < 10 ; i = i + 1 ) begin
            MOSI = addr[i];
            @(negedge clk);
        end

        // test master to write data 
        SS_n = 0;
        MOSI = 0;
        @(negedge clk);
        for ( i = 0 ; i < 10 ; i = i + 1 ) begin
            MOSI = data[i];
            @(negedge clk);
        end

        // test slave to read addr form mem want to read it
        addr = {2'b10,8'h50};
        SS_n = 0;
        MOSI = 1;
        @(negedge clk);
        for ( i = 0 ; i < 10 ; i = i + 1 ) begin
            MOSI = addr[i];
            @(negedge clk);
        end

        // test slave to write data from mem to master
        dummy = {2'b11,8'hff};
        SS_n = 0;
        MOSI = 1;
        @(negedge clk);
        for ( i = 0 ; i <  ; i = i + 1 ) begin
            MOSI = dummy[i];
            @(negedge clk);
            // self check
            if (MISO != data[i+2]) begin
            $display ("ERROR, MISO out is incorrect");
            $stop;
            end
        end
        
        

        $stop;
    end


    initial begin
        $monitor("MOSI=%d,MISO=%d,SS_n=%d,rst_n=%d",MOSI,MISO,SS_n,rst_n);
    end


endmodule