module SPI_TOP(
    MOSI,MISO,SS_n,clk,rst_n
);
    input MOSI,SS_n,clk,rst_n;
    output reg MISO;

    wire [9:0] rx_data,din;
    wire rx_valid,tx_valid;
    wire [7:0] tx_data,dout;

    TEST u0 (MOSI,SS_n,clk,rst_n,MISO,rx_data,tx_data,rx_valid,tx_valid);
    RAM_SPI u1 (din, rx_valid, clk, rst_n, dout, tx_valid);

endmodule